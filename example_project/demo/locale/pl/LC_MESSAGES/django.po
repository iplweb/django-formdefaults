#: demo/templates/demo/search.html:7
msgid ""
"This form opts out of system-wide editing via "
"<code>formdefaults_can_edit_system_wide = lambda user, fr: False</code> — "
"even admins see only the personal button."
msgstr ""
"Ten formularz rezygnuje z edycji wartości systemowych przez "
"<code>formdefaults_can_edit_system_wide = lambda user, fr: False</code> — "
"nawet administratorzy widzą tylko przycisk dla wartości osobistej."

